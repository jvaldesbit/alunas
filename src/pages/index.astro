<script>
/* --- Stepper interactivo --- */
(function () {
  const DURATION = 40000;
  const tabs    = document.querySelectorAll('.stab');
  const panels  = document.querySelectorAll('.step-panel');
  const screens = document.querySelectorAll('.step-screen');
  const bar     = document.querySelector('.stepper-bar');
  let current = 0;
  let timer;

  function goTo(n) {
    tabs.forEach((t, i)    => t.classList.toggle('active', i === n));
    panels.forEach((p, i)  => p.classList.toggle('active', i === n));
    screens.forEach((s, i) => s.classList.toggle('active', i === n));
    current = n;
    bar.style.transition = 'none';
    bar.style.width = '0%';
    bar.offsetWidth; // force reflow
    bar.style.transition = `width ${DURATION}ms linear`;
    bar.style.width = '100%';
  }

  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(() => goTo((current + 1) % tabs.length), DURATION);
  }

  tabs.forEach((tab, i) => tab.addEventListener('click', () => {
    goTo(i);
    resetTimer();
  }));

  goTo(0);
  resetTimer();
}());
</script>

<script>
(function () {
  'use strict';

  const canvas = document.getElementById('spirit-canvas');
  const ctx = canvas.getContext('2d');

  // Paleta espiritual: cian, azul/índigo, violeta, rosa
  const PALETTE = [[175, 200], [215, 250], [258, 295], [308, 345]];

  function randHue() {
    const r = PALETTE[Math.floor(Math.random() * PALETTE.length)];
    return r[0] + Math.random() * (r[1] - r[0]);
  }

  function Spirit(large) {
    this.large = large;
    this.init(true);
  }

  Spirit.prototype.init = function (scatter) {
    if (this.large) {
      this.size  = 28 + Math.random() * 30;
      this.spd   = 0.03 + Math.random() * 0.07;
      this.baseA = 0.06 + Math.random() * 0.12;
    } else {
      this.size  = 5 + Math.random() * 17;
      this.spd   = 0.13 + Math.random() * 0.34;
      this.baseA = 0.30 + Math.random() * 0.48;
    }

    this.x = scatter ? Math.random() * canvas.width  : -this.size * 5;
    this.y = scatter ? Math.random() * canvas.height : Math.random() * canvas.height;

    this.angle  = Math.random() * Math.PI * 2;
    this.angleV = (Math.random() - 0.5) * 0.005;
    this.wobPh  = Math.random() * Math.PI * 2;
    this.wobSpd = 0.006 + Math.random() * 0.010;
    this.wobAmt = 0.35 + Math.random() * 0.65;
    this.hue    = randHue();
    this.targH  = randHue();
    this.brPh   = Math.random() * Math.PI * 2;
    this.brSpd  = 0.006 + Math.random() * 0.012;
    this.flash  = 0;
    this.flashCD = Math.floor(Math.random() * 360); // stagger initial cooldowns
  };

  Spirit.prototype.update = function () {
    this.wobPh += this.wobSpd;
    this.angle += this.angleV + Math.sin(this.wobPh) * this.wobAmt * 0.013;
    this.x     += Math.cos(this.angle) * this.spd;
    this.y     += Math.sin(this.angle) * this.spd;

    const pad = this.size * 5;
    if (this.x < -pad)                 this.x = canvas.width  + pad * 0.5;
    if (this.x > canvas.width  + pad)  this.x = -pad * 0.5;
    if (this.y < -pad)                 this.y = canvas.height + pad * 0.5;
    if (this.y > canvas.height + pad)  this.y = -pad * 0.5;

    const dh = this.targH - this.hue;
    // hue moves faster while flashing so the color shift is visible
    this.hue += dh * (this.flash > 0.1 ? 0.07 : 0.013);
    if (Math.abs(dh) < 3) this.targH = randHue();

    this.brPh += this.brSpd;
    if (this.flash > 0)   this.flash  = Math.max(0, this.flash - 0.014);
    if (this.flashCD > 0) this.flashCD--;
  };

  Spirit.prototype.draw = function () {
    const breathe = 0.65 + 0.35 * Math.sin(this.brPh);
    const a = Math.min(0.95, this.baseA * breathe + this.flash * 0.45);
    const r = this.size * (2.8 + this.flash * 2.5);
    const h = this.hue;

    ctx.save();
    ctx.globalCompositeOperation = 'screen';

    // outer glow
    const g = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, r);
    g.addColorStop(0,    `hsla(${h},90%,97%,${a.toFixed(3)})`);
    g.addColorStop(0.18, `hsla(${h},84%,80%,${(a * 0.80).toFixed(3)})`);
    g.addColorStop(0.52, `hsla(${h},72%,62%,${(a * 0.28).toFixed(3)})`);
    g.addColorStop(1,    `hsla(${h},60%,50%,0)`);

    ctx.beginPath();
    ctx.arc(this.x, this.y, r, 0, Math.PI * 2);
    ctx.fillStyle = g;
    ctx.fill();

    // bright core only when flash is a fresh high spike (not sustained low glow)
    if (this.flash > 0.5) {
      const cr = this.size * 0.9 * this.flash;
      const cg = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, cr);
      cg.addColorStop(0,   `hsla(${h},100%,100%,${this.flash.toFixed(3)})`);
      cg.addColorStop(0.5, `hsla(${h},95%,90%,${(this.flash * 0.4).toFixed(3)})`);
      cg.addColorStop(1,   `hsla(${h},90%,80%,0)`);
      ctx.beginPath();
      ctx.arc(this.x, this.y, cr, 0, Math.PI * 2);
      ctx.fillStyle = cg;
      ctx.fill();
    }

    ctx.restore();
  };

  function interact(a, b) {
    const dx = a.x - b.x;
    const dy = a.y - b.y;
    const th = (a.size + b.size) * 5.5;
    const dSq = dx * dx + dy * dy;
    if (dSq > th * th) return;

    const d  = Math.sqrt(dSq);
    const t  = 1 - d / th;
    const mid = (a.hue + b.hue) / 2;

    // flash is a one-time event gated by cooldown — not a sustained state
    if (t > 0.6 && a.flashCD === 0 && b.flashCD === 0) {
      a.hue    = mid + (Math.random() - 0.5) * 40;
      b.hue    = mid + (Math.random() - 0.5) * 40;
      a.flash  = 0.88;
      b.flash  = 0.88;
      a.flashCD = 360 + Math.floor(Math.random() * 240); // 6–10 s at 60fps
      b.flashCD = 360 + Math.floor(Math.random() * 240);
    } else if (t > 0.2) {
      // approaching: blend color targets quietly, no flash
      a.targH = mid + (Math.random() - 0.5) * 50;
      b.targH = mid + (Math.random() - 0.5) * 50;
    }

    // gentle angular push so they drift apart naturally
    const f  = t * 0.025;
    const nx = dx / d;
    const ny = dy / d;
    a.angle += Math.atan2(ny,  nx)  * f;
    b.angle += Math.atan2(-ny, -nx) * f;
  }

  function resize() {
    const hero = canvas.parentElement;
    canvas.width  = hero.offsetWidth;
    canvas.height = hero.offsetHeight;
  }

  resize();
  window.addEventListener('resize', resize, { passive: true });

  const spirits = [
    ...Array.from({ length: 8  }, () => new Spirit(true)),
    ...Array.from({ length: 38 }, () => new Spirit(false)),
  ];

  let active = true;

  function loop() {
    if (!active) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (const s of spirits) s.update();
    for (let i = 0; i < spirits.length; i++)
      for (let j = i + 1; j < spirits.length; j++)
        interact(spirits[i], spirits[j]);
    for (const s of spirits) s.draw();
    requestAnimationFrame(loop);
  }

  loop();

  document.addEventListener('visibilitychange', () => {
    active = !document.hidden;
    if (active) loop();
  });
}());
</script>

</body>
